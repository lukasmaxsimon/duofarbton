# ─── Duo Farbton — Environment-Vorlage ───────────────────────────────────────
# Diese Datei ist EINGECHECKT und enthält NUR leere Platzhalter.
# Echte Werte gehören in .env (gitignored) bzw. in die Vercel-Projekt-Variablen.
# Niemals echte Secrets hier committen. App liest .env, Git trackt .env.example.

# Postgres (Neon) — für lokal UND Vercel (Prod + Preview).
# Neon-Pooled-Connection-String (enthält ?sslmode=require), Form:
DATABASE_URL=postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# Signiert Login-JWTs/Cookies. Stark & einmalig. Erzeugen: openssl rand -base64 32
PAYLOAD_SECRET=

# Schema-Push nur lokaler Notnagel. In Produktion NIEMALS true (dort Migrationen).
PAYLOAD_DB_PUSH=false

# Nur in Produktion setzen: https://<domain> → aktiviert serverURL/cors/csrf.
# NICHT für Vercel-Preview setzen (CSRF bricht sonst auf den *.vercel.app-URLs).
PAYLOAD_PUBLIC_SERVER_URL=

# Medien-Storage: Vercel Blob. Token aktiviert den Storage-Adapter (Prod/Preview).
# Lokal leer lassen → Uploads landen auf der Festplatte (./media).
BLOB_READ_WRITE_TOKEN=
