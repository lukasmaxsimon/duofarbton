{
  "name": "duofarbton",
  "version": "1.0.0",
  "description": "Website Duo Farbton — Next.js + Payload 3 CMS",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env PAYLOAD_SECRET=duofarbton-local-dev-secret NODE_OPTIONS=--no-deprecation next dev -p ${PORT:-3001}",
    "devsafe": "rm -rf .next && cross-env PAYLOAD_SECRET=duofarbton-local-dev-secret NODE_OPTIONS=--no-deprecation next dev -p ${PORT:-3001}",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed:pages": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/pages.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "sync:media": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/sync-media-to-production.ts",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/live-preview-react": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/plugin-seo": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-vercel-blob": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@vercel/blob": "2.4.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.4.2",
    "graphql": "^16.8.1",
    "lenis": "^1.3.25",
    "next": "16.2.9",
    "payload": "3.85.1",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "prettier": "^3.4.2",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.12.0 <23",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "sharp": "0.34.5",
      "payload>undici": ">=7.28.0",
      "dompurify": ">=3.3.2",
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10"
    }
  }
}
