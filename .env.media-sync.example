# Lokale Vorlage fuer `pnpm sync:media`.
# Kopieren nach `.env.media-sync.local` und dort echte Werte eintragen.
# `.env.media-sync.local` ist durch `.env*.local` gitignored.

# Quelle: Neon-Branch mit den vollstaendigen Medien-Daten.
MEDIA_SYNC_SOURCE_DATABASE_URL=

# Ziel: Production-DB.
MEDIA_SYNC_TARGET_DATABASE_URL=

# Vercel Blob Token der Quelle. Wenn Preview und Production denselben Blob Store
# verwenden, kann hier derselbe Wert wie im Ziel stehen.
MEDIA_SYNC_SOURCE_BLOB_TOKEN=

# Vercel Blob Token des Production Blob Stores.
MEDIA_SYNC_TARGET_BLOB_TOKEN=
